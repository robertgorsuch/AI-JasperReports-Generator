<jasperReport name="county_land_area" language="java" pageWidth="842" pageHeight="595" columnWidth="802" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">
	<query language="SQL"><![CDATA[
SELECT c.name AS county, round((c.aland/2589988.110336)::numeric,1) AS land_sq_mi FROM tiger.county c WHERE c.statefp='48' ORDER BY c.aland DESC LIMIT 20
	]]></query>

	<field name="county" class="java.lang.String"/>
	<field name="land_sq_mi" class="java.math.BigDecimal"/>

