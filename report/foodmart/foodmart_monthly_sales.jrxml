<?xml version="1.0" encoding="UTF-8"?>
<!-- Generated by jasper-deploy scaffold_jrxml.py. JR7-native (JasperReports 7.0.6). -->
<jasperReport name="foodmart_monthly_sales" language="java" pageWidth="842" pageHeight="595" columnWidth="802" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">
	<query language="SQL"><![CDATA[
SELECT lpad(t.month_of_year::text, 2, '0') || ' ' || left(t.the_month, 3) AS month,
       round(sum(s.store_sales), 0)::numeric AS sales
FROM sales_fact_1997 s
JOIN time_by_day t ON t.time_id = s.time_id
GROUP BY t.month_of_year, t.the_month
ORDER BY t.month_of_year
	]]></query>

	<field name="month" class="java.lang.String"/>
	<field name="sales" class="java.math.BigDecimal"/>

	<title height="44">
		<element kind="staticText" x="0" y="0" width="802" height="24" fontSize="16.0" bold="true"><text><![CDATA[Monthly Sales Trend]]></text></element>
		<element kind="staticText" x="0" y="26" width="802" height="14" fontSize="9.0" forecolor="#666666"><text><![CDATA[Foodmart store sales by month]]></text></element>
	</title>

	<columnHeader height="18">
		<element kind="rectangle" x="0" y="0" width="802" height="18" mode="Opaque" backcolor="#34495E" forecolor="#34495E"/>
		<element kind="staticText" x="6" y="0" width="488" height="18" fontSize="9.0" bold="true" forecolor="#FFFFFF" vTextAlign="Middle"><text><![CDATA[Month]]></text></element>
		<element kind="staticText" x="494" y="0" width="302" height="18" fontSize="9.0" bold="true" forecolor="#FFFFFF" hTextAlign="Right" vTextAlign="Middle"><text><![CDATA[Sales]]></text></element>
	</columnHeader>

	<detail>
		<band height="13">
		<element kind="textField" x="6" y="0" width="488" height="13" fontSize="8.0" vTextAlign="Middle"><expression><![CDATA[$F{month}]]></expression></element>
		<element kind="textField" x="494" y="0" width="302" height="13" fontSize="8.0" hTextAlign="Right" vTextAlign="Middle" pattern="#,##0.00"><expression><![CDATA[$F{sales}]]></expression></element>
			<element kind="line" x="0" y="12" width="802" height="1" forecolor="#EEEEEE"/>
		</band>
	</detail>

	<pageFooter height="16">
		<element kind="staticText" x="0" y="2" width="401" height="12" fontSize="8.0" forecolor="#666666"><text><![CDATA[Monthly Sales Trend]]></text></element>
		<element kind="textField" x="647" y="2" width="120" height="12" forecolor="#666666" fontSize="8.0" hTextAlign="Right"><expression><![CDATA["Page " + $V{PAGE_NUMBER} + " of"]]></expression></element>
		<element kind="textField" x="769" y="2" width="33" height="12" forecolor="#666666" fontSize="8.0" evaluationTime="Report"><expression><![CDATA[" " + $V{PAGE_NUMBER}]]></expression></element>
	</pageFooter>

	<summary height="400">
		<element kind="chart" chartType="line" x="0" y="10" width="802" height="380" evaluationTime="Report">
			<dataset kind="category">
				<series>
					<seriesExpression><![CDATA["Sales"]]></seriesExpression>
					<categoryExpression><![CDATA[$F{month}]]></categoryExpression>
					<valueExpression><![CDATA[$F{sales}]]></valueExpression>
				</series>
			</dataset>
			<plot showLines="true" showShapes="true"/>
		</element>
	</summary>

</jasperReport>
