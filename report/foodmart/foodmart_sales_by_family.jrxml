<?xml version="1.0" encoding="UTF-8"?>
<!-- Generated by jasper-deploy scaffold_jrxml.py. JR7-native (JasperReports 7.0.6). -->
<jasperReport name="foodmart_sales_by_family" language="java" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">
	<query language="SQL"><![CDATA[
SELECT pc.product_family AS product_family,
       round(sum(s.store_sales), 0)::numeric AS sales
FROM sales_fact_1997 s
JOIN product p ON p.product_id = s.product_id
JOIN product_class pc ON pc.product_class_id = p.product_class_id
GROUP BY pc.product_family
ORDER BY sales DESC
	]]></query>

	<field name="product_family" class="java.lang.String"/>
	<field name="sales" class="java.math.BigDecimal"/>

	<title height="44">
		<element kind="staticText" x="0" y="0" width="555" height="24" fontSize="16.0" bold="true"><text><![CDATA[Sales by Product Family]]></text></element>
		<element kind="staticText" x="0" y="26" width="555" height="14" fontSize="9.0" forecolor="#666666"><text><![CDATA[Revenue composition across product families]]></text></element>
	</title>

	<columnHeader height="18">
		<element kind="rectangle" x="0" y="0" width="555" height="18" mode="Opaque" backcolor="#34495E" forecolor="#34495E"/>
		<element kind="staticText" x="6" y="0" width="336" height="18" fontSize="9.0" bold="true" forecolor="#FFFFFF" vTextAlign="Middle"><text><![CDATA[Product Family]]></text></element>
		<element kind="staticText" x="342" y="0" width="207" height="18" fontSize="9.0" bold="true" forecolor="#FFFFFF" hTextAlign="Right" vTextAlign="Middle"><text><![CDATA[Sales]]></text></element>
	</columnHeader>

	<detail>
		<band height="13">
		<element kind="textField" x="6" y="0" width="336" height="13" fontSize="8.0" vTextAlign="Middle"><expression><![CDATA[$F{product_family}]]></expression></element>
		<element kind="textField" x="342" y="0" width="207" height="13" fontSize="8.0" hTextAlign="Right" vTextAlign="Middle" pattern="#,##0.00"><expression><![CDATA[$F{sales}]]></expression></element>
			<element kind="line" x="0" y="12" width="555" height="1" forecolor="#EEEEEE"/>
		</band>
	</detail>

	<pageFooter height="16">
		<element kind="staticText" x="0" y="2" width="277" height="12" fontSize="8.0" forecolor="#666666"><text><![CDATA[Sales by Product Family]]></text></element>
		<element kind="textField" x="400" y="2" width="120" height="12" forecolor="#666666" fontSize="8.0" hTextAlign="Right"><expression><![CDATA["Page " + $V{PAGE_NUMBER} + " of"]]></expression></element>
		<element kind="textField" x="522" y="2" width="33" height="12" forecolor="#666666" fontSize="8.0" evaluationTime="Report"><expression><![CDATA[" " + $V{PAGE_NUMBER}]]></expression></element>
	</pageFooter>

	<summary height="400">
		<element kind="chart" chartType="pie3D" x="0" y="10" width="555" height="380" evaluationTime="Report">
			<dataset kind="pie">
				<series>
					<keyExpression><![CDATA[$F{product_family}]]></keyExpression>
					<valueExpression><![CDATA[$F{sales}]]></valueExpression>
				</series>
			</dataset>
			<plot labelFormat="{0}: {2}" legendLabelFormat="{0} ({2})"/>
		</element>
	</summary>

</jasperReport>
