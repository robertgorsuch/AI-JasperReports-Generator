			<element kind="line" x="0" y="12" width="802" height="1" forecolor="#EEEEEE"/>
		</band>
	</detail>

	<pageFooter height="16">
		<element kind="staticText" x="0" y="2" width="401" height="12" fontSize="8.0" forecolor="#666666"><text><![CDATA[Profit by Store]]></text></element>
