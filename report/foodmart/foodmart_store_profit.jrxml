		<element kind="staticText" x="494" y="0" width="302" height="18" fontSize="9.0" bold="true" forecolor="#FFFFFF" hTextAlign="Right" vTextAlign="Middle"><text><![CDATA[Profit]]></text></element>
	</columnHeader>

	<detail>
