		<element kind="staticText" x="312" y="0" width="300" height="18" fontSize="9.0" bold="true" forecolor="#FFFFFF" vTextAlign="Middle"><text><![CDATA[Year]]></text></element>
		<element kind="staticText" x="612" y="0" width="184" height="18" fontSize="9.0" bold="true" forecolor="#FFFFFF" hTextAlign="Right" vTextAlign="Middle"><text><![CDATA[Sales]]></text></element>
	</columnHeader>

	<detail>
		<band height="13">
		<element kind="textField" x="6" y="0" width="300" height="13" fontSize="8.0" vTextAlign="Middle"><expression><![CDATA[$F{month}]]></expression></element>
		<element kind="textField" x="312" y="0" width="300" height="13" fontSize="8.0" vTextAlign="Middle"><expression><![CDATA[$F{year}]]></expression></element>
		<element kind="textField" x="612" y="0" width="184" height="13" fontSize="8.0" hTextAlign="Right" vTextAlign="Middle" pattern="#,##0.00"><expression><![CDATA[$F{sales}]]></expression></element>
			<element kind="line" x="0" y="12" width="802" height="1" forecolor="#EEEEEE"/>
		</band>
	</detail>

	<pageFooter height="16">
		<element kind="staticText" x="0" y="2" width="401" height="12" fontSize="8.0" forecolor="#666666"><text><![CDATA[Year-over-Year Sales (1997 vs 1998)]]></text></element>
		<element kind="textField" x="647" y="2" width="120" height="12" forecolor="#666666" fontSize="8.0" hTextAlign="Right"><expression><![CDATA["Page " + $V{PAGE_NUMBER} + " of"]]></expression></element>
		<element kind="textField" x="769" y="2" width="33" height="12" forecolor="#666666" fontSize="8.0" evaluationTime="Report"><expression><![CDATA[" " + $V{PAGE_NUMBER}]]></expression></element>
	</pageFooter>

	<summary height="400">
