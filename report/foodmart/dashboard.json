{
  "db": "foodmart",
  "host": "localhost",
  "port": "5432",
  "user": "postgres",
  "dataSourceUri": "/public/Samples/Data_Sources/FoodmartDataSource",
  "folder": "/reports/foodmart",
  "name": "foodmart_kpi_dashboard_auto",
  "label": "Foodmart KPI Dashboard (auto-composed)",
  "outDir": "report\\foodmart",
  "dashlets": [
    {
      "name": "foodmart_yoy_sales",
      "title": "Year-over-Year Sales (1997 vs 1998)",
      "subtitle": "Monthly store sales compared across years",
      "chart": "bar", "chartCategory": "month", "chartValue": "sales", "chartSeries": "year",
      "chartHeight": 380, "landscape": true,
      "queryFile": "report\\foodmart\\yoy_sales.sql",
      "x": 0, "y": 0, "width": 40, "height": 10
    },
    {
      "name": "foodmart_sales_by_family",
      "title": "Sales by Product Family",
      "subtitle": "Revenue composition across product families",
      "chart": "pie3d", "chartHeight": 380,
      "queryFile": "report\\foodmart\\sales_by_family.sql",
      "x": 0, "y": 10, "width": 20, "height": 11
    },
    {
      "name": "foodmart_top_categories",
      "title": "Top 10 Product Categories",
      "subtitle": "Highest-revenue categories",
      "chart": "bar", "chartHeight": 380, "landscape": true,
      "queryFile": "report\\foodmart\\top_categories.sql",
      "x": 20, "y": 10, "width": 20, "height": 11
    },
    {
      "name": "foodmart_quarterly_sales_by_family",
      "title": "Quarterly Sales by Family",
      "subtitle": "Sales per quarter, stacked by product family",
      "chart": "stackedbar", "chartCategory": "quarter", "chartValue": "sales", "chartSeries": "family",
      "chartHeight": 380, "landscape": true,
      "queryFile": "report\\foodmart\\quarterly_sales_by_family.sql",
      "x": 0, "y": 21, "width": 22, "height": 11
    },
    {
      "name": "foodmart_monthly_sales",
      "title": "Monthly Sales Trend",
      "subtitle": "Foodmart store sales by month",
      "chart": "line", "chartHeight": 380, "landscape": true,
      "queryFile": "report\\foodmart\\monthly_sales.sql",
      "x": 22, "y": 21, "width": 18, "height": 11
    },
    {
      "name": "foodmart_store_profit",
      "title": "Profit by Store",
      "subtitle": "Gross profit (sales - cost) by store city",
      "chart": "bar", "chartHeight": 380, "landscape": true,
      "queryFile": "report\\foodmart\\store_profit.sql",
      "x": 0, "y": 32, "width": 22, "height": 10
    },
    {
      "name": "foodmart_promotion_effectiveness",
      "title": "Promotion Effectiveness",
      "subtitle": "Sales attributed to each promotional media type",
      "chart": "bar", "chartHeight": 380, "landscape": true, "chartLabelRotation": -45,
      "queryFile": "report\\foodmart\\promotion_effectiveness.sql",
      "x": 22, "y": 32, "width": 18, "height": 10
    }
  ]
}
