<?xml version="1.0" encoding="UTF-8"?>
<!-- Generated by jasper-deploy scaffold_jrxml.py. JR7-native (JasperReports 7.0.6). -->
<jasperReport name="metro_population_bar" language="java" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">
	<query language="SQL"><![CDATA[
SELECT metro, sum(pop)::bigint AS population FROM (SELECT CASE WHEN countyfp IN ('201','157','339','039','167','291','473','071','015') THEN 'Houston' WHEN countyfp IN ('113','439','085','121','139','251','257','397','367','231','497','221','425') THEN 'Dallas-Fort Worth' WHEN countyfp IN ('029','091','187','493','013','019','259','325') THEN 'San Antonio' WHEN countyfp IN ('453','491','209','021','055') THEN 'Austin' WHEN countyfp IN ('141','229') THEN 'El Paso' WHEN countyfp IN ('215') THEN 'McAllen-Edinburg' WHEN countyfp IN ('355','409','007') THEN 'Corpus Christi' ELSE 'Rest of Texas' END AS metro, pop FROM (SELECT countyfp, sum(pop)::bigint AS pop FROM tiger_data.tx_tabblock20 GROUP BY countyfp) cp) m GROUP BY metro ORDER BY population DESC
	]]></query>

	<field name="metro" class="java.lang.String"/>
	<field name="population" class="java.lang.Long"/>

	<title height="44">
		<element kind="staticText" x="0" y="0" width="555" height="24" fontSize="16.0" bold="true" hTextAlign="Center"><text><![CDATA[Texas Population by Metro Area (Bar)]]></text></element>
