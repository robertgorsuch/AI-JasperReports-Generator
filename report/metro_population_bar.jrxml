	</columnHeader>

	<detail>
		<band height="13">
		<element kind="textField" x="6" y="0" width="335" height="13" fontSize="8.0" vTextAlign="Middle"><expression><![CDATA[$F{metro}]]></expression></element>
		<element kind="textField" x="341" y="0" width="208" height="13" fontSize="8.0" hTextAlign="Right" vTextAlign="Middle" pattern="#,##0"><expression><![CDATA[$F{population}]]></expression></element>
