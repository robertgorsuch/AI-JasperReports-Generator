<?xml version="1.0" encoding="UTF-8"?>
<!-- Generated by jasper-deploy scaffold_jrxml.py. JR7-native (JasperReports 7.0.6). -->
<jasperReport name="tx_housing_pie" language="java" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">
	<query language="SQL"><![CDATA[
SELECT c.name AS county, sum(b.housing)::bigint AS housing_units FROM tiger_data.tx_tabblock20 b JOIN tiger.county c ON c.statefp=b.statefp AND c.countyfp=b.countyfp WHERE b.statefp='48' GROUP BY c.name ORDER BY 2 DESC LIMIT 15
	]]></query>

	<field name="county" class="java.lang.String"/>
	<field name="housing_units" class="java.lang.Long"/>

	<title height="28">
		<element kind="staticText" x="0" y="0" width="555" height="24" fontSize="16.0" bold="true"><text><![CDATA[Texas Housing Units by County]]></text></element>
	</title>

	<columnHeader height="18">
		<element kind="rectangle" x="0" y="0" width="555" height="18" mode="Opaque" backcolor="#34495E" forecolor="#34495E"/>
		<element kind="staticText" x="6" y="0" width="336" height="18" fontSize="9.0" bold="true" forecolor="#FFFFFF" vTextAlign="Middle"><text><![CDATA[County]]></text></element>
		<element kind="staticText" x="342" y="0" width="207" height="18" fontSize="9.0" bold="true" forecolor="#FFFFFF" hTextAlign="Right" vTextAlign="Middle"><text><![CDATA[Housing Units]]></text></element>
	</columnHeader>

	<detail>
		<band height="13">
		<element kind="textField" x="6" y="0" width="336" height="13" fontSize="8.0" vTextAlign="Middle"><expression><![CDATA[$F{county}]]></expression></element>
		<element kind="textField" x="342" y="0" width="207" height="13" fontSize="8.0" hTextAlign="Right" vTextAlign="Middle" pattern="#,##0"><expression><![CDATA[$F{housing_units}]]></expression></element>
			<element kind="line" x="0" y="12" width="555" height="1" forecolor="#EEEEEE"/>
		</band>
	</detail>

	<pageFooter height="16">
		<element kind="staticText" x="0" y="2" width="277" height="12" fontSize="8.0" forecolor="#666666"><text><![CDATA[Texas Housing Units by County]]></text></element>
		<element kind="textField" x="400" y="2" width="120" height="12" forecolor="#666666" fontSize="8.0" hTextAlign="Right"><expression><![CDATA["Page " + $V{PAGE_NUMBER} + " of"]]></expression></element>
		<element kind="textField" x="522" y="2" width="33" height="12" forecolor="#666666" fontSize="8.0" evaluationTime="Report"><expression><![CDATA[" " + $V{PAGE_NUMBER}]]></expression></element>
	</pageFooter>

	<summary height="320">
		<element kind="chart" chartType="pie" x="0" y="10" width="555" height="300" evaluationTime="Report">
			<dataset kind="pie">
				<series>
					<keyExpression><![CDATA[$F{county}]]></keyExpression>
					<valueExpression><![CDATA[$F{housing_units}]]></valueExpression>
				</series>
			</dataset>
			<plot labelFormat="{0}: {2}" legendLabelFormat="{0} ({2})"/>
		</element>
	</summary>

</jasperReport>
